# Copy to .env and fill in real values. Never commit .env.

# --- Database (local Postgres via Docker, see docker-compose.yml) ---
DATABASE_URL="postgresql://wwwelly:wwwelly_dev_password@localhost:5432/wwwelly?schema=public"

# --- Better Auth ---
# Generate a strong secret for real environments, e.g.: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Dev and prod need separate OAuth clients (different authorized redirect URIs) in
# https://console.cloud.google.com/apis/credentials
# Redirect URI to authorize: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic (Claude API, for the AI task-planning assistant) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_TASK_PLANNER_MODEL="claude-haiku-4-5"

# --- Resend (password reset + support form emails) ---
# https://resend.com/api-keys — without this, emails just log a warning
# instead of sending (dev-safe no-op).
RESEND_API_KEY=""
# Must be a verified domain in Resend for production; the default only
# delivers to the Resend account's own inbox.
RESEND_FROM_EMAIL="wwwelly <onboarding@resend.dev>"

# --- Vercel Blob (photos for pets/vehicles/children/avatars) ---
# Created automatically when you add a Blob store in Vercel → Storage.
BLOB_READ_WRITE_TOKEN=""
